{# Compute module: GCE instances, MIGs, Cloud Run services #}
{%- for c in classified %}
  {%- set a = c.resource.attributes %}
  {%- if c.resource.asset_type == "compute.googleapis.com/Instance" %}

resource "google_compute_instance" "{{ c.address }}" {
  name         = "{{ c.resource.name }}"
  project      = var.project_id
  zone         = "{{ c.resource.location }}"
  machine_type = "{{ (a.get('machineType') or '').rsplit('/', 1)[-1] }}"

  {% for disk in a.get('disks', []) %}
    {% if loop.first %}
  boot_disk {
    auto_delete = {{ disk.get('autoDelete', true) | tojson }}
    {% if disk.get('source') %}
    source = "{{ disk['source'] }}"
    {% endif %}
  }
    {% else %}
  attached_disk {
    source = "{{ disk.get('source', '') }}"
  }
    {% endif %}
  {% endfor %}

  {% for nic in a.get('networkInterfaces', []) %}
  network_interface {
    network    = "{{ nic.get('network', '') }}"
    {% if nic.get('subnetwork') %}
    subnetwork = "{{ nic['subnetwork'] }}"
    {% endif %}
    {% for ac in nic.get('accessConfigs', []) %}
    access_config {
      {% if ac.get('natIP') %}
      nat_ip = "{{ ac['natIP'] }}"
      {% endif %}
    }
    {% endfor %}
  }
  {% endfor %}

  labels = {{ labels | tojson }}
}
  {%- elif c.resource.asset_type == "run.googleapis.com/Service" %}

resource "google_cloud_run_v2_service" "{{ c.address }}" {
  name     = "{{ c.resource.name }}"
  project  = var.project_id
  location = "{{ c.resource.location }}"
  ingress  = "{{ a.get('ingress', 'INGRESS_TRAFFIC_ALL') }}"

  template {
    {% for container in (a.get('template', {}).get('containers') or []) %}
    containers {
      image = "{{ container.get('image', '') }}"
      {% for port in container.get('ports', []) %}
      ports {
        container_port = {{ port.get('containerPort', 8080) }}
      }
      {% endfor %}
    }
    {% endfor %}
  }

  labels = {{ labels | tojson }}
}
  {%- endif %}
{%- endfor %}
